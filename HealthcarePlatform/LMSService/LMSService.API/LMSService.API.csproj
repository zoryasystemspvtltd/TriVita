<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Asp.Versioning.Mvc" Version="8.1.1" />
    <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer" Version="8.1.1" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.11" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.EntityFrameworkCore" Version="8.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore.Annotations" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="logs\.gitkeep" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\BuildingBlocks\Healthcare.Common\Healthcare.Common.csproj" />
    <ProjectReference Include="..\..\BuildingBlocks\Healthcare.Swagger\Healthcare.Swagger.csproj" />
    <ProjectReference Include="..\LMSService.Application\LMSService.Application.csproj" />
    <ProjectReference Include="..\LMSService.Infrastructure\LMSService.Infrastructure.csproj" />
  </ItemGroup>

  <Target Name="CopyApplicationXmlDocumentation" AfterTargets="Build">
    <Copy
      SourceFiles="$(ProjectDir)..\LMSService.Application\bin\$(Configuration)\net8.0\LMSService.Application.xml"
      DestinationFolder="$(OutDir)"
      SkipUnchangedFiles="true"
      Condition="Exists('$(ProjectDir)..\LMSService.Application\bin\$(Configuration)\net8.0\LMSService.Application.xml')" />
  </Target>

</Project>
